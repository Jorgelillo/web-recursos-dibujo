---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const tareas = await getCollection('tareas');
  return tareas.map(entry => ({
    params: { slug: entry.slug },
    props: { tarea: entry },
  }));
}

const { tarea } = Astro.props;
const { Content } = await tarea.render();
---

<Layout 
  title={`${tarea.data.titulo} | Recursos de Plástica`}
  description={tarea.data.descripcion || `Instrucciones y lámina descargable para la tarea de ${tarea.data.titulo}.`}
  image={tarea.data.imagenPortada.src}
>

  <article class="container mx-auto px-4 sm:px-6 max-w-4xl py-12">

    <header class="mb-12">

    <!-- Botón de volver -->
    <a href={`/asignaturas/${tarea.data.asignatura}`} class="inline-flex items-center gap-2 text-indigo-600 hover:text-indigo-800 font-medium mb-8 transition group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transform group-hover:-translate-x-1 transition" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        </svg>
        Volver a la asignatura
    </a>

    <!-- Título y descripción -->
    <h1 class="text-4xl md:text-5xl font-extrabold mb-6 text-gray-900 tracking-tight">{tarea.data.titulo}</h1>
    <p class="text-xl md:text-2xl text-gray-600 leading-relaxed font-light mb-8">{tarea.data.descripcion}</p>

    
    
    <!-- Fecha y Técnica -->
    <div class="flex flex-wrap items-center gap-3 pb-8 border-b border-gray-100">
        <span class="inline-flex items-center gap-1.5 bg-pink-50 text-pink-700 px-4 py-1.5 rounded-full font-semibold text-sm shadow-sm border border-pink-100">
            🎨 {tarea.data.tecnica || 'Técnica Variada'}
        </span>
        
        {tarea.data.tematicas?.map(tema => (
          <a href={`/tematicas/${tema.toLowerCase().replace(/ /g, '-')}`} class="inline-flex items-center gap-1.5 bg-orange-50 hover:bg-orange-100 text-orange-800 px-4 py-1.5 rounded-full text-sm font-medium transition duration-200 border border-orange-200">
            🎃 {tema}
          </a>
        ))}

        {tarea.data.artistas?.map(artista => (
          <a href={`/artistas/${artista.toLowerCase().replace(/ /g, '-')}`} class="inline-flex items-center gap-1.5 bg-purple-50 hover:bg-purple-100 text-purple-800 px-4 py-1.5 rounded-full text-sm font-medium transition duration-200 border border-purple-200">
            👩‍🎨 {artista}
          </a>
        ))}

        {tarea.data.etiquetas?.map(tag => (
          <a href={`/etiquetas/${tag.toLowerCase()}`} class="text-gray-500 hover:text-indigo-600 text-sm font-medium transition duration-200">
            #{tag}
          </a>
        ))}
      </div>
    </header>

    <!-- Contenido del Recurso  -->
    <div class="prose prose-lg prose-indigo max-w-none mb-16 text-gray-800">
      <Content />
    </div>

    <!-- Material Descargable  -->
    {(tarea.data.pdfAdjunto || tarea.data.presentacion) && (
      <section class="mb-10 bg-indigo-50/50 rounded-3xl p-8 md:p-12 border border-indigo-100 shadow-sm">
        <h2 class="text-2xl font-bold text-indigo-900 mb-8 flex items-center gap-2">
          🧰 Material de Apoyo
        </h2>

        {tarea.data.pdfAdjunto && (
        <div class="mb-10 bg-white p-6 rounded-2xl border border-indigo-100 shadow-sm flex flex-col sm:flex-row items-center justify-between gap-6">
          <div>
            <h3 class="text-lg font-bold text-gray-900">Plantilla / Ficha de trabajo</h3>
            <p class="text-gray-600 text-sm mt-1">Abre el PDF en una pestaña nueva para visualizarlo, imprimirlo o descargarlo.</p>
          </div>
          <a 
            href={tarea.data.pdfAdjunto} 
            target="_blank"
            rel="noopener noreferrer"
            class="shrink-0 w-full sm:w-auto flex justify-center items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-6 rounded-xl shadow-md hover:shadow-lg transition-all transform hover:-translate-y-0.5"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            Ver Ficha en PDF
          </a>
        </div>
      )}
      
        {tarea.data.presentacion && (
          <div class="w-full">
            <h3 class="text-lg font-bold text-gray-900 mb-4">Diapositivas de clase</h3>
            <div class="aspect-video w-full rounded-2xl overflow-hidden shadow-md border border-gray-200 bg-white">
              <iframe 
                src={tarea.data.presentacion} 
                class="w-full h-full border-0"
                allowfullscreen="true">
              </iframe>
            </div>
            <p class="text-center text-sm text-indigo-600/80 mt-3 flex items-center justify-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M3 4a1 1 0 011-1h4a1 1 0 010 2H6.414l2.293 2.293a1 1 0 01-1.414 1.414L5 6.414V8a1 1 0 01-2 0V4zm9 1a1 1 0 110-2h4a1 1 0 011 1v4a1 1 0 11-2 0V6.414l-2.293 2.293a1 1 0 11-1.414-1.414L13.586 5H12zm-9 7a1 1 0 112 0v1.586l2.293-2.293a1 1 0 011.414 1.414L6.414 15H8a1 1 0 110 2H4a1 1 0 01-1-1v-4zm13-1a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 110-2h1.586l-2.293-2.293a1 1 0 011.414-1.414L15 13.586V12a1 1 0 011-1z" clip-rule="evenodd" />
              </svg>
              Úsalas a pantalla completa para ver mejor los detalles.
            </p>
          </div>
        )}
      </section>
    )}
   
    <!-- Trabajos de los alumnos/as  -->
    {tarea.data.ejemplosAlumnos && tarea.data.ejemplosAlumnos.length > 0 && (
      <section class="mt-8 pt-10 border-t border-gray-100">
        <div class="text-center mb-10">
          <h2 class="text-3xl font-bold text-gray-900 mb-3">Inspiración: Trabajos de clase 🎨</h2>
          <p class="text-gray-500">Ejemplos reales creados por alumnos. ¡Haz clic para ampliar!</p>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4 sm:gap-6">
          {tarea.data.ejemplosAlumnos.map((imgAlumno, index) => (
            <figure class="cursor-zoom-in lightbox-trigger group overflow-hidden rounded-2xl shadow-sm border border-gray-100 bg-gray-50 aspect-square" data-src={imgAlumno.src}>
              <Image 
                src={imgAlumno} 
                alt={`Ejemplo de alumno ${index + 1}`} 
                class="w-full h-full object-cover group-hover:scale-105 transition duration-500 ease-out"
              />
            </figure>
          ))}
        </div>
      </section>
    )}

  </article>

<div id="lightbox" class="fixed inset-0 z-[100] bg-gray-900/95 hidden grid place-items-center p-4 sm:p-8 backdrop-blur-sm opacity-0 transition-opacity duration-300">
    <button id="lightbox-close" class="absolute top-4 right-4 sm:top-8 sm:right-8 text-white/70 hover:text-white text-5xl font-light transition w-12 h-12 flex items-center justify-center rounded-full hover:bg-white/10 z-10">
      &times;
    </button>
    <img id="lightbox-img" src="" alt="Imagen ampliada" class="max-w-[90vw] max-h-[85vh] md:max-w-4xl lg:max-w-5xl object-contain rounded-lg shadow-2xl scale-95 transition-transform duration-300" /></div>
</Layout>

<script>
  // Ejecutamos el código directamente
  const triggers = document.querySelectorAll('.lightbox-trigger');
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const closeBtn = document.getElementById('lightbox-close');

  if (triggers.length > 0 && lightbox && lightboxImg && closeBtn) {
      
      // Función para cerrar
      const closeLightbox = () => {
          lightbox.classList.add('opacity-0');
          lightboxImg.classList.remove('scale-100');
          lightboxImg.classList.add('scale-95');
          
          // Esperar a que acabe la animación
          setTimeout(() => {
              lightbox.classList.add('hidden');
              lightboxImg.setAttribute('src', '');
              document.body.style.overflow = ''; // Restaurar scroll
          }, 300);
      };

      // Función para abrir
      triggers.forEach(trigger => {
          trigger.addEventListener('click', () => {
              const src = trigger.getAttribute('data-src');
              if (src) {
                  lightboxImg.setAttribute('src', src);
                  lightbox.classList.remove('hidden');
                  
                  // Pequeño retraso para la animación
                  requestAnimationFrame(() => {
                      lightbox.classList.remove('opacity-0');
                      lightboxImg.classList.remove('scale-95');
                      lightboxImg.classList.add('scale-100');
                  });
                  document.body.style.overflow = 'hidden'; // Quitar scroll de fondo
              }
          });
      });

      // Eventos de cierre
      closeBtn.addEventListener('click', closeLightbox);
      
      lightbox.addEventListener('click', (e) => {
          if (e.target === lightbox) closeLightbox(); 
      });
      
      document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !lightbox.classList.contains('hidden')) {
              closeLightbox();
          }
      });
  }
</script>